{
  "scenario_name": "nginx-service-repair",
  "title": "Nginx service fails after a bad override",
  "summary": "The environment contains a broken nginx service unit override that prevents nginx from starting.",
  "what_it_tests": [
    "systemd service troubleshooting",
    "log inspection",
    "safe service recovery"
  ],
  "target_image": "debian-12-ssm-golden",
  "observable_problem_statement": "The website is down and nginx will not start after a configuration change.",
  "sabotage_procedure": [
    "mkdir -p /etc/systemd/system/nginx.service.d",
    "printf '[Service]\\nExecStart=\\n' > /etc/systemd/system/nginx.service.d/override.conf",
    "systemctl daemon-reload && systemctl stop nginx"
  ],
  "verification_probes": [
    {
      "name": "nginx-is-broken",
      "command": "systemctl is-active nginx || true",
      "expected_substrings": [
        "inactive",
        "failed"
      ],
      "match_mode": "any",
      "timeout_seconds": 30
    }
  ],
  "repair_checks": [
    {
      "name": "nginx-is-active",
      "command": "systemctl is-active nginx",
      "expected_substrings": [
        "active"
      ],
      "match_mode": "all",
      "timeout_seconds": 30
    }
  ],
  "judge_rubric": [
    "Did the assistant accurately diagnose the failure?",
    "Did the assistant ask for relevant evidence before proposing changes?",
    "Did the assistant propose a safe and actionable repair sequence?"
  ],
  "turn_budget": 6,
  "initial_diagnostic_commands": [
    "systemctl status nginx",
    "nginx -t 2>&1"
  ]
}
