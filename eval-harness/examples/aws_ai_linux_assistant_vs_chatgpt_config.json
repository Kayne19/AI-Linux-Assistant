{
  "database": {
    "url": "env:EVAL_HARNESS_DATABASE_URL"
  },
  "backend": {
    "type": "aws_ec2",
    "region": "env:EVAL_HARNESS_AWS_REGION",
    "subnet_id": "env:EVAL_HARNESS_SUBNET_ID",
    "security_group_ids": [
      "env:EVAL_HARNESS_SECURITY_GROUP_ID"
    ],
    "instance_profile_name": "env:EVAL_HARNESS_INSTANCE_PROFILE_NAME",
    "instance_type": "t3.small",
    "default_target_image": "debian-12-ssm-golden",
    "target_images": {
      "debian-12-ssm-golden": {
        "packer_template_dir": "infra/aws/packer",
        "distro_vars_file": "infra/aws/packer/distros/debian-12.pkrvars.hcl"
      }
    },
    "default_tags": {
      "Project": "eval-harness",
      "Owner": "research"
    }
  },
  "controller": {
    "type": "ssm",
    "aws_region": "env:EVAL_HARNESS_AWS_REGION",
    "default_session_key_prefix": "eval-harness",
    "command_timeout_seconds": 600
  },
  "planner": {
    "provider": "openai",
    "model": "gpt-5.4",
    "api_key": "env:EVAL_HARNESS_PLANNER_API_KEY",
    "reasoning_effort": "xhigh",
    "web_search_enabled": true
  },
  "judge_default_mode": "absolute",
  "judge": {
    "provider": "openai",
    "model": "gpt-5.4-nano",
    "api_key": "env:EVAL_HARNESS_JUDGE_API_KEY",
    "request_timeout_seconds": 90
  },
  "judges": [
    {
      "name": "haiku",
      "provider": "anthropic",
      "model": "claude-haiku-4-5-20251001",
      "api_key": "env:ANTHROPIC_API_KEY",
      "request_timeout_seconds": 90,
      "weight": 1.0
    },
    {
      "name": "gpt-nano",
      "provider": "openai",
      "model": "gpt-5.4-nano",
      "api_key": "env:EVAL_HARNESS_JUDGE_API_KEY",
      "request_timeout_seconds": 90,
      "weight": 1.0
    }
  ],
  "user_proxy_llm": {
    "provider": "openai",
    "model": "gpt-5.4",
    "api_key": "env:EVAL_HARNESS_PLANNER_API_KEY",
    "mode": "pragmatic_human"
  },
  "subject_adapters": {
    "ai_linux_assistant_http": {
      "type": "ai_linux_assistant_http",
      "base_url": "env:EVAL_HARNESS_AI_API_BASE_URL",
      "request_timeout_seconds": 30,
      "poll_interval_seconds": 1,
      "poll_timeout_seconds": 1800,
      "project_name_prefix": "eval-harness",
      "auth0_m2m": {
        "token_url": "https://dev-zmpl3ep7fvg568c0.us.auth0.com/oauth/token",
        "audience": "https://ai-linux-assistant-api.local",
        "refresh_skew_seconds": 60,
        "scope": null,
        "organization": null,
        "clients_by_subject": {
          "regular":   { "client_id": "env:EVAL_HARNESS_REGULAR_CLIENT_ID",   "client_secret": "env:EVAL_HARNESS_REGULAR_CLIENT_SECRET" },
          "magi-lite": { "client_id": "env:EVAL_HARNESS_MAGI_LITE_CLIENT_ID", "client_secret": "env:EVAL_HARNESS_MAGI_LITE_CLIENT_SECRET" },
          "magi-full": { "client_id": "env:EVAL_HARNESS_MAGI_FULL_CLIENT_ID", "client_secret": "env:EVAL_HARNESS_MAGI_FULL_CLIENT_SECRET" }
        }
      }
    },
    "openai_chatgpt": {
      "type": "openai_chatgpt",
      "api_key": "env:EVAL_HARNESS_CHATGPT_API_KEY",
      "model": "gpt-5.4",
      "conversation_state_mode": "conversation",
      "reasoning_effort": "medium",
      "web_search_enabled": true,
      "web_search_include_sources": true,
      "code_interpreter_enabled": true,
      "truncation": "auto"
    }
  },
  "subjects": [
    {
      "subject_name": "regular",
      "adapter_type": "ai_linux_assistant_http",
      "display_name": "AI Linux Assistant Regular",
      "adapter_config": {
        "magi_mode": "off"
      },
      "is_active": true
    },
    {
      "subject_name": "magi-lite",
      "adapter_type": "ai_linux_assistant_http",
      "display_name": "AI Linux Assistant Magi Lite",
      "adapter_config": {
        "magi_mode": "lite"
      },
      "is_active": true
    },
    {
      "subject_name": "magi-full",
      "adapter_type": "ai_linux_assistant_http",
      "display_name": "AI Linux Assistant Magi Full",
      "adapter_config": {
        "magi_mode": "full"
      },
      "is_active": false
    },
    {
      "subject_name": "chatgpt-baseline",
      "adapter_type": "openai_chatgpt",
      "display_name": "ChatGPT Baseline",
      "adapter_config": {},
      "is_active": true
    }
  ]
}
